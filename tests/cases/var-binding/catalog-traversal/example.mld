/import { @importedWriteTools } from "./catalog-traversal-imported-tools.mld"

/var known @recipient = "ada"

/record @send_email_inputs = {
  facts: [recipient: string],
  data: [subject: string],
  validate: "strict"
}

/exe tool:w @sendEmail(recipient, subject) = `sent:@recipient:@subject`

/var tools @writeTools = {
  sendEmail: {
    mlld: @sendEmail,
    inputs: @send_email_inputs,
    labels: ["execute:w"]
  }
}

/exe @catalogWalk(catalog) = js {
  const first = Object.entries(catalog)[0][1];
  const second = Object.entries(catalog)[0][1];
  return [
    `entries=${Object.keys(catalog).length}`,
    `stableEntry=${first === second}`,
    `stableLabels=${Array.isArray(first?.labels) && first.labels === second.labels}`,
    `hasInputs=${Boolean(first?.inputs)}`,
    `hasMlld=${Boolean(first?.mlld)}`
  ].join(';');
}

/var @baseSubset = {
  sendEmail: @writeTools.sendEmail
}

/var @entry = @writeTools.sendEmail

/var @spreadSubset = {
  ...@baseSubset
}

/var @importedSubset = {
  sendEmail: @importedWriteTools.sendEmail
}

/var @intent = {
  known: {
    sendEmail: {
      recipient: {
        value: "ada",
        source: "user"
      }
    }
  }
}

/var @built = @policy.build(@intent, @writeTools)

/show @catalogWalk({ sendEmail: @writeTools.sendEmail })
/show @catalogWalk({ sendEmail: @entry })
/show @catalogWalk(@baseSubset)
/show @catalogWalk(@spreadSubset)
/show @catalogWalk(@importedSubset)
/show @built.valid
/show @writeTools.sendEmail(@recipient, "hello")
