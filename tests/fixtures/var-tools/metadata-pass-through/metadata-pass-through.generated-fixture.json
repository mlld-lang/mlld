  "category": "valid",
  "subcategory": "metadata-pass-through",
  "input": "/var known @recipient = \"ada@example.com\"\n\n/record @send_email_inputs = {\n  facts: [recipient: string],\n  data: [subject: string],\n  validate: \"strict\"\n}\n\n/exe @send_email(recipient, subject, retries, settings) = js {\n  return `sent:${recipient}:${subject}:${retries}:${settings.mode}`;\n}\n\n/exe @catalogSummary(keyed, entries) = js {\n  const entry = entries[0][1];\n  return JSON.stringify({\n    keyed: {\n      mlld: keyed.mlld.name,\n      inputs: keyed.inputs.name,\n      labels: keyed.labels,\n      description: keyed.description,\n      instructions: keyed.instructions,\n      can_authorize: keyed.can_authorize,\n      bind: keyed.bind\n    },\n    entries: {\n      mlld: entry.mlld.name,\n      inputs: entry.inputs.name,\n      labels: entry.labels,\n      description: entry.description,\n      instructions: entry.instructions,\n      can_authorize: entry.can_authorize,\n      bind: entry.bind\n    }\n  }, null, 2);\n}\n\n/var tools @agentTools = {\n  send_email: {\n    mlld: @send_email,\n    inputs: @send_email_inputs,\n    labels: [\"execute:w\", \"comm:w\"],\n    description: \"Send mail\",\n    instructions: \"Prefer drafts first.\",\n    can_authorize: \"role:planner\",\n    bind: { retries: 3, settings: { mode: \"safe\" } }\n  }\n}\n\n/show @catalogSummary(@agentTools.send_email, @agentTools.mx.entries)\n/show @agentTools.send_email(@recipient, \"hello\")\n",
  "expected": "{\n  \"keyed\": {\n    \"mlld\": \"send_email\",\n    \"inputs\": \"send_email_inputs\",\n    \"labels\": [\n      \"execute:w\",\n      \"comm:w\"\n    ],\n    \"description\": \"Send mail\",\n    \"instructions\": \"Prefer drafts first.\",\n    \"can_authorize\": \"role:planner\",\n    \"bind\": {\n      \"retries\": 3,\n      \"settings\": {\n        \"mode\": \"safe\"\n      }\n    }\n  },\n  \"entries\": {\n    \"mlld\": \"send_email\",\n    \"inputs\": \"send_email_inputs\",\n    \"labels\": [\n      \"execute:w\",\n      \"comm:w\"\n    ],\n    \"description\": \"Send mail\",\n    \"instructions\": \"Prefer drafts first.\",\n    \"can_authorize\": \"role:planner\",\n    \"bind\": {\n      \"retries\": 3,\n      \"settings\": {\n        \"mode\": \"safe\"\n      }\n    }\n  }\n}\nsent:ada@example.com:hello:3:safe\n",
