>> LLM Docs Build Script
>> Reads shared categories config, builds XML-wrapped modules from atoms,
>> then assembles llms-combined.txt
>> Usage: mlld run llmstxt

var @pkg = <@root/package.json>
var @version = @pkg.version
var @config = <@root/docs/build/categories.json>
var @atomsRoot = "@root/docs/src/atoms"

exe @strip(content) = js {
  return content.replace(/^---[\s\S]*?---\n*/, '').trim();
}

exe @wrap(tag, body) = js {
  return '<' + tag + '>\n' + body + '\n</' + tag + '>';
}

exe @wrapPadded(tag, body) = js {
  return '<' + tag + '>\n\n' + body + '\n\n</' + tag + '>\n';
}

exe @flatten(sections) = js {
  return sections.flat().join('\n\n');
}

>> Build each category
for @catName, @catConfig in @config [
  let @tag = @catConfig.tag
  let @sections = for @group in @catConfig.groups [
    >> Use source directory if specified, otherwise category name
    let @srcDir = @group.source ? @group.source : @catName
    let @atomContents = for @atomName in @group.atoms [
      let @raw = <@atomsRoot/@srcDir/@atomName\.md>
      => @strip(@raw)
    ]
    if @group.parent [
      let @parentTag = @group.parent.replaceAll("-", "_").toUpperCase()
      let @body = @atomContents.join("\n\n")
      => @wrap(@parentTag, @body)
    ]
    >> Standalone: each atom gets its own tag
    => for @i, @atomContent in @atomContents [
      let @atomTag = @group.atoms[@i].replaceAll("-", "_").toUpperCase()
      => @wrap(@atomTag, @atomContent)
    ]
  ]

  let @flat = @flatten(@sections)
  let @module = @wrapPadded(@tag, @flat)

  output @module to `@root/docs/llm/llms-@catName\.txt`
  log `  Built llms-@catName\.txt`
]

>> Assemble combined document from all modules (including manually maintained ones)
var @moduleOrder = [
  "llms-overview.txt",
  "llms-core-rules.txt",
  "llms-language-reference.txt",
  "llms-flow-control.txt",
  "llms-modules.txt",
  "llms-patterns.txt",
  "llms-cli.txt",
  "llms-configuration.txt",
  "llms-sdk.txt",
  "llms-mistakes.txt",
  "llms-security.txt",
  "llms-reference.txt",
  "llms-cookbook.txt"
]

var @contents = for @module in @moduleOrder => <@root/docs/llm/@module>

exe @buildDoc(version, timestamp, body) = js {
  return '<MLLD_COMPLETE_GUIDE version="' + version + '">\n\nThis is the complete mlld reference guide, combining all documentation modules.\nFor modular access, see individual files in docs/llm/.\n\nGenerated: ' + timestamp + '\n\n' + body + '\n\n</MLLD_COMPLETE_GUIDE>\n';
}

var @body = @contents.join("\n\n")
var @combined = @buildDoc(@version, @now, @body)

output @combined to "@root/llms-combined.txt"
show `Built llms-combined.txt (version @version)`
