>> Topics Library
>> Topic discovery from atom frontmatter and filtering

>> Load all topics from atoms filtered by qa_tier
>> No --tier: returns ALL atoms with an id (regardless of qa_tier)
>> With --tier: returns only atoms matching those tiers
exe @loadTopics(tier) = [
  let @atomFiles = <@base/docs/src/atoms/**/*.md>
  let @tiers = @tier ? @tier.split(",") : []
  when @tiers.length > 0 => for @f in @atomFiles when @f.mx.fm.qa_tier && @f.mx.fm.id && !@f.mx.fm.id.startsWith("_") && @tiers.includes(`@f.mx.fm.qa_tier`) => @f.mx.fm.id
  => for @f in @atomFiles when @f.mx.fm.id && !@f.mx.fm.id.startsWith("_") => @f.mx.fm.id
]

>> Filter topics by --topic (prefix) or --topics (comma list)
exe @filterTopics(all, filter, list) = when [
  @list => for @t in @all when @list.split(",").includes(@t) => @t
  @filter => for @t in @all when @t == @filter || @t.startsWith(@filter) => @t
  * => @all
]

/export {
  @loadTopics,
  @filterTopics
}
