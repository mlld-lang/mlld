>> Slop Audit — ticket-aware anti-slop orchestrator
>>
>> Usage:
>>   mlld run slop-audit
>>   mlld run slop-audit --files "cli/commands/analyze.ts,cli/mcp/BuiltinTools.ts"
>>   mlld run slop-audit --since HEAD~10
>>   mlld run slop-audit --branch main..2.1.0
>>   mlld run slop-audit --full true
>>   mlld run slop-audit --maxIterations 8
>>   mlld run slop-audit --parallel 4
>>   mlld run slop-audit --plannerModel opus
>>   mlld run slop-audit --workerModel togetherai/zai-org/GLM-5.1
>>   mlld run slop-audit --name slop-audit-2026-04-25
>>
>> Design:
>>   Strict llm-first. The script gathers raw context, asks an Opus planner
>>   what to do, and mechanically dispatches scope or audit-batch actions.
>>   Ticket interpretation, code exploration, duplicate detection, and ticket
>>   creation rules live in prompts and agent tool use, not mlld conditionals.

needs { sh }
import { @claude } from @mlld/claude
import { @opencode } from @mlld/opencode

>> Config
var @maxIterations = @payload.maxIterations ? @payload.maxIterations * 1 : 5
var @parallelism = @payload.parallel ? @payload.parallel * 1 : 4
var @plannerModel = @payload.plannerModel ?? "opus"
var @workerModel = @payload.workerModel ?? "togetherai/zai-org/GLM-5.1"
var @today = cmd { date -u +%Y-%m-%d }
var @runName = @payload.name ?? @payload.run ?? `slop-audit-@today`
var @runDir = `@root/llm/output/@runName`
var @lastRunCommitFile = <@root/llm/output/.slop-audit-last-commit>?
var @lastRunCommit = when [
  @payload.lastRunCommit => @payload.lastRunCommit
  @lastRunCommitFile => @lastRunCommitFile.trim()
  * => ""
]
var @fullFlag = @payload.full ?? @payload.all ?? ""
var @scopeFlags = {
  files: @payload.files ?? "",
  since: @payload.since ?? "",
  branch: @payload.branch ?? "",
  full: @fullFlag,
  lastRunCommit: @lastRunCommit
}

run sh { mkdir -p "$runDir/prompts" "$runDir/responses" "$runDir/batches" }

>> The planner can inspect the repo and manage tickets directly.
var @plannerTools = [
  "Read",
  "Write",
  "Glob",
  "Grep",
  "Bash(tk:*)",
  "Bash(git:*)",
  "Bash(rg:*)",
  "Bash(nl:*)",
  "Bash(sed:*)",
  "Bash(mlld:*)"
]

>> Reference material
var @antiSlopGuide = <@root/docs/dev/ANTI-SLOP.md>

>> Prompt templates
exe @decisionPrompt(context, guide) = template "./prompts/decision.att"
exe @scopePrompt(flags, context, guide) = template "./prompts/scope.att"
exe @reviewPrompt(unit, context, guide) = template "./prompts/review.att"
exe @verifyPrompt(unit, reviewResult, context, guide) = template "./prompts/verify.att"
exe @draftPrompt(unit, reviewResult, verifyResult, context, guide) = template "./prompts/draft.att"

>> Raw context snapshots. These are intentionally simple: agents decide how to
>> interpret them and can use tools to dig deeper.
exe @ticketSnapshot() = sh {
  tk list --dir anti-slop || true
}

exe @gitSnapshot() = sh {
  printf 'branch: '
  git branch --show-current
  printf '\nstatus:\n'
  git status --short
}

exe @recentEvents(runDir) = sh {
  if [ -f "$runDir/events.jsonl" ]; then
    tail -40 "$runDir/events.jsonl"
  fi
}

exe @buildContext(iteration, lastWorkerResult, lastError) = [
  let @tickets = @ticketSnapshot()
  let @git = @gitSnapshot()
  let @events = @recentEvents(@runDir)
  => `<goal>
Audit the mlld codebase for violations of docs/dev/ANTI-SLOP.md and keep work tracked in tk under --dir anti-slop.
</goal>

<run>
name: @runName
dir: @runDir
iteration: @iteration
max_iterations: @maxIterations
parallelism: @parallelism
</run>

<scope_flags>
@scopeFlags
</scope_flags>

<ticket_snapshot command="tk list --dir anti-slop">
@tickets
</ticket_snapshot>

<git_snapshot>
@git
</git_snapshot>

<recent_events>
@events
</recent_events>

<last_worker_result>
@lastWorkerResult
</last_worker_result>

<last_error>
@lastError
</last_error>`
]

exe llm @callPlanner(prompt, model, tools) = @claude(@prompt, {
  model: @model,
  dir: @root,
  tools: @tools
})

exe llm @callWorker(prompt, model) = @opencode(@prompt, {
  model: @model,
  dir: @root,
  pure: true,
  bypass: true
})

exe @runAuditUnit(unit, unitIndex, context, guide, model, runDir, iteration) = [
  let @unitDir = `@runDir/batches/iteration-@iteration/unit-@unitIndex`
  run sh { mkdir -p "$unitDir" }

  let @reviewPromptText = @reviewPrompt(@unit, @context, @guide)
  output @reviewPromptText to `@unitDir/review.prompt.md`
  let @reviewRaw = @callWorker(@reviewPromptText, @model)
  output @reviewRaw to `@unitDir/review.txt`

  let @verifyPromptText = @verifyPrompt(@unit, @reviewRaw, @context, @guide)
  output @verifyPromptText to `@unitDir/verify.prompt.md`
  let @verifyRaw = @callWorker(@verifyPromptText, @model)
  output @verifyRaw to `@unitDir/verify.txt`

  let @draftPromptText = @draftPrompt(@unit, @reviewRaw, @verifyRaw, @context, @guide)
  output @draftPromptText to `@unitDir/draft.prompt.md`
  let @draftRaw = @callWorker(@draftPromptText, @model)
  output @draftRaw to `@unitDir/draft.txt`

  => {
    unit: @unit,
    artifacts: { dir: @unitDir },
    review: @reviewRaw,
    verify: @verifyRaw,
    draft: @draftRaw
  }
]

show `Slop Audit`
show `Name: @runName`
show `Run: @runDir`
show `Planner: @plannerModel`
show `Worker: @workerModel`
show `Parallelism: @parallelism`

var @runResult = loop(@maxIterations) [
  let @state = when [
    @input["_slop_audit_state"] == "state" => @input
    * => {
      _slop_audit_state: "state",
      iteration: 1,
      lastWorkerResult: "",
      lastError: ""
    }
  ]

  let @context = @buildContext(@state.iteration, @state.lastWorkerResult, @state.lastError)
  let @plannerPromptText = @decisionPrompt(@context, @antiSlopGuide)
  let @plannerPromptPath = `@runDir/prompts/planner-@state.iteration\.md`
  output @plannerPromptText to @plannerPromptPath

  show `\nIteration @state.iteration: planning...`
  let @decisionRaw = @callPlanner(@plannerPromptText, @plannerModel, @plannerTools)
  output @decisionRaw to "@runDir/responses/planner-@state.iteration\.txt"
  let @decision = @decisionRaw | @parse.llm

  append {
    type: "planner_decision",
    iteration: @state.iteration,
    action: @decision.action,
    reasoning: @decision.reasoning ?? null
  } to "@runDir/events.jsonl"

  when @decision.action [
    "scope" => [
      let @scopePromptText = @scopePrompt(@scopeFlags, @context, @antiSlopGuide)
      let @scopePromptPath = `@runDir/prompts/scope-@state.iteration\.md`
      output @scopePromptText to @scopePromptPath

      show `Iteration @state.iteration: resolving audit scope...`
      let @scopeRaw = @callWorker(@scopePromptText, @workerModel)
      output @scopeRaw to "@runDir/responses/scope-@state.iteration\.txt"

      append {
        type: "scope_result",
        iteration: @state.iteration,
        prompt: @scopePromptPath,
        summary: @scopeRaw
      } to "@runDir/events.jsonl"

      continue {
        _slop_audit_state: "state",
        iteration: @state.iteration + 1,
        lastWorkerResult: @scopeRaw,
        lastError: ""
      }
    ]

    "audit_batch" => [
      let @units = @decision.units ?? []
      output @decision to "@runDir/responses/audit-batch-@state.iteration\.json"

      show `Iteration @state.iteration: auditing @units.length units...`
      let @batchResults = for parallel(@parallelism) @unit in @units [
        let @unitIndex = @mx.for.index
        let @result = @runAuditUnit(@unit, @unitIndex, @context, @antiSlopGuide, @workerModel, @runDir, @state.iteration)
        => @result
      ]
      output @batchResults to "@runDir/responses/audit-batch-@state.iteration-results.json"

      append {
        type: "audit_batch_result",
        iteration: @state.iteration,
        units: @units,
        results: @batchResults
      } to "@runDir/events.jsonl"

      continue {
        _slop_audit_state: "state",
        iteration: @state.iteration + 1,
        lastWorkerResult: @batchResults,
        lastError: ""
      }
    ]

    "blocked" => [
      let @questions = @decision.questions ?? []
      output @decision to "@runDir/blocked.json"
      append {
        type: "blocked",
        iteration: @state.iteration,
        questions: @questions
      } to "@runDir/events.jsonl"
      done {
        status: "blocked",
        questions: @questions,
        message: `Blocked. See @runDir/blocked.json`
      }
    ]

    "complete" => [
      let @summary = @decision.summary ?? "complete"
      let @currentCommit = cmd { git rev-parse HEAD }
      output @currentCommit to "@root/llm/output/.slop-audit-last-commit"
      output @decision to "@runDir/complete.json"
      append {
        type: "complete",
        iteration: @state.iteration,
        summary: @summary
      } to "@runDir/events.jsonl"
      done {
        status: "complete",
        summary: @summary,
        message: `Complete. See @runDir/complete.json`
      }
    ]

    * => [
      continue {
        _slop_audit_state: "state",
        iteration: @state.iteration + 1,
        lastWorkerResult: @state.lastWorkerResult,
        lastError: `Planner returned unknown action. Raw response saved in @runDir/responses/planner-@state.iteration\.txt`
      }
    ]
  ]
]

show `\n@runResult.message`
