{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Slop Audit Review Result",
  "type": "object",
  "required": ["file", "summary", "findings"],
  "properties": {
    "file": { "type": "string" },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "line", "severity", "category", "issue", "evidence", "correction"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "category": {
            "type": "string",
            "enum": [
              "redundant-guard",
              "unknown-duck-typing",
              "duplicated-utility",
              "obvious-comment",
              "belt-and-suspenders",
              "one-use-abstraction",
              "catch-rethrow",
              "over-handling",
              "as-any-escape"
            ]
          },
          "issue": { "type": "string" },
          "evidence": { "type": "string" },
          "correction": { "type": "string" }
        }
      }
    }
  }
}